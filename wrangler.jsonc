{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "web-vault",
  "compatibility_date": "2026-05-11",

  "workers_dev": false,

  "placement": { "mode": "smart" },

  "assets": {
    "directory": "./apps/web/build/",
    "not_found_handling": "404-page",
  },

  "observability": {
    "traces": {
      "enabled": true,
      "destinations": ["grafana-traces"],
    },
    "logs": {
      "enabled": true,
      "destinations": ["grafana-logs"],
    },
  },
}
